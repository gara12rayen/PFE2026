# ============================================================
#  TalentFlow ATS — .gitignore
# ============================================================

# ── Python / FastAPI Backend ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/

# Environment variables (NEVER commit — contains secrets)
.env

# Uploaded CVs (user data — never commit)
app/uploads/
uploads/

# SQLAlchemy / Alembic
*.db
*.sqlite3

# pytest
.pytest_cache/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
*.egg-info/

# ── Node.js / React Frontend ─────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React build output
build/
dist/

# Environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDEs & Editors ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
